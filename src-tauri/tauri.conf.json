{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rekord-lib",
  "version": "0.3.1",
  "identifier": "com.timheinrichs.rekord-lib",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rekord-lib",
        "width": 1100,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/timheinrichs/rekord-lib/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2QkExMDZEOEQ1NjE5NTIKUldSU0dWYU5iUkM2OWlRcUlQN3VOV3UxYXMxNitsdUcxbXJITFF6K3dFWkxQKzh3R0k3elZERHIK"
    }
  }
}
